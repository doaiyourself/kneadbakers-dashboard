# ============================================================
# KNEAD Analytics — Environment Variables
# 복사: cp .env.local.example .env.local 후 실제 값으로 채우기
# ============================================================

# --- Database ---
# PostgreSQL connection string (TimescaleDB 확장이 있으면 자동 활용)
# 예: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

# --- Toss Place Open API ---
# https://docs.tossplace.com/reference/open-api/intro.html
TOSS_BASE_URL=https://open-api.tossplace.com/api-public/openapi/v1
TOSS_ACCESS_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
TOSS_MERCHANT_ID=

# --- NextAuth v5 (Kakao OAuth 전용) ---
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Kakao Developers (https://developers.kakao.com/console/app) ---
# 1) 애플리케이션 생성 → 앱 키 → REST API 키 = KAKAO_CLIENT_ID
# 2) 카카오 로그인 → 활성화 ON
# 3) 카카오 로그인 → Redirect URI 등록:
#    http://localhost:3000/api/auth/callback/kakao
#    https://<배포 도메인>/api/auth/callback/kakao
# 4) 카카오 로그인 → 동의항목 → 카카오계정(이메일) 필수/선택 동의
# 5) 보안 → Client Secret 코드 생성 → 활성 → KAKAO_CLIENT_SECRET
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- 접근 권한 (화이트리스트) ---
# 매출 데이터 보호: 등록된 카카오 계정만 로그인 가능. 둘 중 하나는 채울 것.
# - OWNER_KAKAO_EMAILS: 카카오 계정 이메일 (콤마 구분). 추천.
# - OWNER_KAKAO_IDS: 카카오 사용자 ID (숫자, 콤마 구분). 이메일 동의 안 했을 때 폴백.
# 둘 다 비어 있으면 첫 로그인 사용자가 자동 owner (TOFU, 개발 편의 — 운영은 비권장).
OWNER_KAKAO_EMAILS=
OWNER_KAKAO_IDS=

# --- Cron / Webhook 보호 ---
# /api/cron/* 호출 시 Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- 알림 (선택) ---
# SLACK_WEBHOOK_URL=
# RESEND_API_KEY=
# ALERT_EMAIL_FROM=

# --- 모니터링 (선택) ---
# NEXT_PUBLIC_SENTRY_DSN=

{
  "name": "kneadbakers-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "test:toss-connection": "tsx -r dotenv/config src/scripts/test-toss-connection.ts dotenv_config_path=.env.local",
    "backfill": "tsx -r dotenv/config src/scripts/backfill.ts dotenv_config_path=.env.local"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "eslint-config-next": "^14.2.35",
    "lucide-react": "^1.16.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
